-- Problem: Find invalid tweets (more than 15 characters)
-- Platform: LeetCode
-- Concept: WHERE clause with LENGTH function

SELECT tweet_id
FROM Tweets
WHERE LENGTH(content) > 15;

-- Explanation:
-- LENGTH(content) returns the number of characters in each tweet
-- WHERE LENGTH(content) > 15 filters tweets longer than 15 characters
-- Only tweets exceeding the limit are considered invalid
